@Library('my-shared-lib') _

def props = variables()

pipeline {
    parameters {
        choice(name: 'ENV', choices: ['dev', 'prod'], description: 'Environment to deploy to')
    }
    agent any

    environment {
        // INFISICAL_TOKEN = credentials('infisical-machine-token')
        // SENTRY_AUTH_TOKEN = credentials('sentry-auth-token')
    }

    stages {
        stage('Initialize') {
            steps {
                script {    
                    try {
                        checkout scm
                    } catch (e) {
                         error "Initialization failed: ${e.getMessage()}"
                    }
                }
            }
        }

        stage('Prepare Image Tag') {
            steps {
                script {
                    try {
                  env.IMG_TAG = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
                //   env.SENTRY_RELEASE = "rushinotes-backend@${env.IMG_TAG}"
                //   echo "Sentry Release: ${env.SENTRY_RELEASE}"
                //   echo "Backend image tag: ${env.IMG_TAG}"
                    } catch (e) {
                        error "Failed to prepare backend image tag: ${e.getMessage()}"
                    }
                }
            }
        }
        
        // stage('Create Sentry Release') {
        //     steps {
        //         script {
        //             sh """
        //                 sentry-cli --url ${props.SENTRY_URL} releases --org ${props.SENTRY_ORG} --project ${props.SENTRY_PROJECT} new ${env.SENTRY_RELEASE}
        //                 sentry-cli --url ${props.SENTRY_URL} releases --org ${props.SENTRY_ORG} --project ${props.SENTRY_PROJECT} set-commits ${env.SENTRY_RELEASE} --auto
        //                 sentry-cli --url ${props.SENTRY_URL} releases --org ${props.SENTRY_ORG} --project ${props.SENTRY_PROJECT} finalize ${env.SENTRY_RELEASE}
        //             """
        //         }
        //     }
        // }




        stage('Build & Push Backend Image') {
            steps {
                script {
                    try {
                dir("${props.APP_PATH}/backend") {
                    withEnv(["IMG_NAME=backend"]) {
                        script { dockerBuildAndPush() }
                    }
                }

                    } catch (e) {
                        error "Backend image build or push failed: ${e.getMessage()}"
                    }
                }
            }
        }

        stage('Prepare EC2 Instance') {
            steps {
                script {
                    try {
                        prepareInstance()
                    } catch (e) {
                        error "EC2 Environment setup failed: ${e.getMessage()}"
                    }
                }
            }
        }

        stage('Transfer Backend Files') {
            steps {
                script {
                    try {
                        generateEnv()
                        transferfile("${props.BACKEND_COMPOSE_FILE} .env")
                    } catch (e) {
                        error "File transfer failed: ${e.getMessage()}"
                    }
                }
            }
        }

        stage('Deploy Backend') {
            steps {
                script {
                    try {
                        dockerComposeDeploy(props.BACKEND_COMPOSE_FILE)
                    } catch (e) {
                        error "Remote deployment on EC2 failed: ${e.getMessage()}"
                    }
                }
            }
        }
        stage('Mark Sentry Deployment') {
            steps {
                script {
                    sh """
                        sentry-cli --url ${props.SENTRY_URL} releases --org ${props.SENTRY_ORG} --project ${props.SENTRY_PROJECT} deploys ${env.SENTRY_RELEASE} new -e ${params.ENV}
                    """
                }
            }
        }



    }

    post {
        success {
            echo "Backend pipeline completed and deployed successfully"
        }
        failure {
            echo "Backend pipeline failed during execution"
        }
        always {
            sh "rm -f ${props.APP_PATH}/.env || true"
        }
    }
}

